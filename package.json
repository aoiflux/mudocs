		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"fast-glob": "^3.3.3",
		"gray-matter": "^4.0.3",
		"marked": "^18.0.6",
		"zod": "^4.4.3"

{
	"name": "site",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"sync:wasm": "node ./scripts/sync-wasm-repl.mjs",
		"predev": "npm run sync:wasm",
		"prebuild": "npm run sync:wasm",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
